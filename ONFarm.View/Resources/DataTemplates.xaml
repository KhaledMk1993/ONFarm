<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:ONFarm.View.Views"
    xmlns:vm="clr-namespace:ONFarm.ViewModel;assembly=ONFarm.ViewModel">

    <!--  Dashboard  -->
    <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
        <views:DashboardView />
    </DataTemplate>

    <!--  Patient List  -->
    <DataTemplate DataType="{x:Type vm:PatientListViewModel}">
        <views:PatientListView />
    </DataTemplate>

    <!--  Agenda  -->
    <DataTemplate DataType="{x:Type vm:AgendaViewModel}">
        <views:AgendaView />
    </DataTemplate>

    <!--  Rappels  -->
    <DataTemplate DataType="{x:Type vm:RappelsViewModel}">
        <views:RappelsView />
    </DataTemplate>

    <!--  Patient Form  -->
    <DataTemplate DataType="{x:Type vm:PatientFormViewModel}">
        <views:PatientFormView />
    </DataTemplate>

</ResourceDictionary>