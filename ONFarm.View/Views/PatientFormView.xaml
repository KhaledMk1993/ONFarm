<UserControl
    x:Class="ONFarm.View.Views.PatientFormView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:ONFarm.ViewModel;assembly=ONFarm.ViewModel"
    d:DataContext="{d:DesignInstance Type=viewmodel:PatientFormViewModel}"
    Background="#F8F9FA"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  Couleurs professionnelles  -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#0052CC" />
        <SolidColorBrush x:Key="PrimaryHover" Color="#0043A3" />
        <SolidColorBrush x:Key="AccentColor" Color="#00D9FF" />
        <SolidColorBrush x:Key="SuccessColor" Color="#28A745" />
        <SolidColorBrush x:Key="DangerColor" Color="#DC3545" />
        <SolidColorBrush x:Key="BackgroundColor" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderColor" Color="#E0E0E0" />
        <SolidColorBrush x:Key="TextPrimary" Color="#212529" />
        <SolidColorBrush x:Key="TextSecondary" Color="#6C757D" />
        <SolidColorBrush x:Key="PlaceholderColor" Color="#ADB5BD" />

        <!--  Style TextBox moderne  -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BackgroundColor}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,10,12,10" />
            <Setter Property="Height" Value="40" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryColor}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            x:Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                VerticalAlignment="Center"
                                VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="PART_Border" Property="BorderBrush" Value="{StaticResource PrimaryColor}" />
                                <Setter TargetName="PART_Border" Property="Effect">
                                    <Setter.Value>
                                        <!--  FIX: DropShadow → DropShadowEffect (WPF)  -->
                                        <DropShadowEffect
                                            BlurRadius="8"
                                            Opacity="0.1"
                                            ShadowDepth="0" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="PART_Border" Property="BorderBrush" Value="{StaticResource PrimaryColor}" />
                                <Setter TargetName="PART_Border" Property="BorderThickness" Value="2" />
                                <Setter TargetName="PART_Border" Property="Effect">
                                    <Setter.Value>
                                        <!--  FIX: DropShadow → DropShadowEffect (WPF)  -->
                                        <DropShadowEffect
                                            BlurRadius="12"
                                            Opacity="0.15"
                                            ShadowDepth="0"
                                            Color="#0052CC" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Style DatePicker moderne  -->
        <Style x:Key="ModernDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Background" Value="{StaticResource BackgroundColor}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,10,12,10" />
            <Setter Property="Height" Value="40" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <!--  Style CheckBox moderne  -->
        <Style x:Key="ModernCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="8,6,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <Border
                                x:Name="CheckBoxBorder"
                                Width="20"
                                Height="20"
                                Background="{StaticResource BackgroundColor}"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1"
                                CornerRadius="4">
                                <TextBlock
                                    x:Name="CheckMark"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource SuccessColor}"
                                    Text="✓"
                                    Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{StaticResource PrimaryColor}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="{StaticResource SuccessColor}" />
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{StaticResource SuccessColor}" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Style Button Primary  -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="24,12,24,12" />
            <Setter Property="Height" Value="44" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <!--  FIX: "600" → SemiBold (WPF named value)  -->
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="PART_Border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="PART_Border" Property="Background" Value="{StaticResource PrimaryHover}" />
                                <Setter TargetName="PART_Border" Property="Effect">
                                    <Setter.Value>
                                        <!--  FIX: empty Effect → proper DropShadowEffect  -->
                                        <DropShadowEffect
                                            BlurRadius="10"
                                            Opacity="0.2"
                                            ShadowDepth="2" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="PART_Border" Property="Effect">
                                    <Setter.Value>
                                        <!--  FIX: DropShadow → DropShadowEffect (WPF)  -->
                                        <DropShadowEffect
                                            BlurRadius="6"
                                            Opacity="0.15"
                                            ShadowDepth="0" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="PART_Border" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Style Button Secondary  -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="24,12,24,12" />
            <Setter Property="Height" Value="44" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <!--  FIX: "600" → SemiBold (WPF named value)  -->
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="PART_Border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="PART_Border" Property="Background" Value="#F0F2F5" />
                                <Setter TargetName="PART_Border" Property="BorderBrush" Value="{StaticResource TextSecondary}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="PART_Border" Property="Background" Value="#E8EAED" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <!--  FIX: Grid does not support Padding → wrap in Border  -->
        <Border Padding="32,40,32,40" Background="#F8F9FA">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Header avec titre et description  -->
                <StackPanel Grid.Row="0" Margin="0,0,0,32">
                    <TextBlock
                        FontFamily="Segoe UI"
                        FontSize="28"
                        FontWeight="Bold"
                        Foreground="{StaticResource TextPrimary}"
                        Text="{Binding Titre}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontFamily="Segoe UI"
                        FontSize="14"
                        Foreground="{StaticResource TextSecondary}"
                        Text="Veuillez remplir les informations du patient. Les champs marqués d'un * sont obligatoires." />
                </StackPanel>

                <!--  Section 1: Informations personnelles  -->
                <Border
                    Grid.Row="1"
                    Padding="28"
                    Background="{StaticResource BackgroundColor}"
                    CornerRadius="8">
                    <Border.Effect>
                        <!--  FIX: DropShadow → DropShadowEffect (WPF)  -->
                        <DropShadowEffect
                            BlurRadius="8"
                            Opacity="0.08"
                            ShadowDepth="1" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,20"
                            FontFamily="Segoe UI"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimary}"
                            Text="Informations personnelles" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Nom  -->
                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,12,20">
                                <TextBlock
                                    Margin="0,0,0,8"
                                    FontFamily="Segoe UI"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimary}"
                                    Text="Nom *" />
                                <TextBox Style="{StaticResource ModernTextBoxStyle}" Text="{Binding Nom, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <!--  Prénom  -->
                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="1"
                                Margin="12,0,0,20">
                                <TextBlock
                                    Margin="0,0,0,8"
                                    FontFamily="Segoe UI"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimary}"
                                    Text="Prénom *" />
                                <TextBox Style="{StaticResource ModernTextBoxStyle}" Text="{Binding Prenom, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <!--  Téléphone  -->
                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,0,12,20">
                                <TextBlock
                                    Margin="0,0,0,8"
                                    FontFamily="Segoe UI"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimary}"
                                    Text="Téléphone" />
                                <TextBox Style="{StaticResource ModernTextBoxStyle}" Text="{Binding Telephone, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <!--  Adresse  -->
                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="12,0,0,20">
                                <TextBlock
                                    Margin="0,0,0,8"
                                    FontFamily="Segoe UI"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimary}"
                                    Text="Adresse" />
                                <TextBox Style="{StaticResource ModernTextBoxStyle}" Text="{Binding Adresse, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <!--  Date de naissance  -->
                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="0"
                                Margin="0,0,12,0">
                                <TextBlock
                                    Margin="0,0,0,8"
                                    FontFamily="Segoe UI"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimary}"
                                    Text="Date de naissance" />
                                <DatePicker SelectedDate="{Binding DateNaissance}" Style="{StaticResource ModernDatePickerStyle}" />
                            </StackPanel>

                            <!--  Statut  -->
                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="1"
                                Margin="12,0,0,0"
                                VerticalAlignment="Bottom">
                                <CheckBox
                                    Content="Patient actif"
                                    IsChecked="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}"
                                    Style="{StaticResource ModernCheckBoxStyle}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!--  Section 2: Notes  -->
                <Border
                    Grid.Row="2"
                    Margin="0,20,0,0"
                    Padding="28"
                    Background="{StaticResource BackgroundColor}"
                    CornerRadius="8">
                    <Border.Effect>
                        <!--  FIX: empty Effect → proper DropShadowEffect  -->
                        <DropShadowEffect
                            BlurRadius="8"
                            Opacity="0.08"
                            ShadowDepth="1" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,20"
                            FontFamily="Segoe UI"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimary}"
                            Text="Notes additionnelles" />

                        <TextBlock
                            Margin="0,0,0,8"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimary}"
                            Text="Notes" />
                        <TextBox
                            Height="100"
                            Padding="12,10,12,10"
                            VerticalAlignment="Top"
                            AcceptsReturn="True"
                            Background="{StaticResource BackgroundColor}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            Foreground="{StaticResource TextPrimary}"
                            Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto">
                            <TextBox.Template>
                                <ControlTemplate TargetType="TextBox">
                                    <Border
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6">
                                        <!--  FIX: PART_ContentHost must be a ScrollViewer, not TextBlock  -->
                                        <ScrollViewer
                                            x:Name="PART_ContentHost"
                                            Margin="{TemplateBinding Padding}"
                                            VerticalAlignment="Top"
                                            VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}" />
                                    </Border>
                                </ControlTemplate>
                            </TextBox.Template>
                        </TextBox>
                    </StackPanel>
                </Border>

                <!--  Actions Buttons  -->
                <StackPanel
                    Grid.Row="3"
                    Margin="0,32,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button
                        Margin="0,0,12,0"
                        Command="{Binding CancelCommand}"
                        Content="Annuler"
                        Style="{StaticResource SecondaryButtonStyle}" />
                    <Button
                        Command="{Binding SaveCommand}"
                        Content="Enregistrer"
                        Style="{StaticResource PrimaryButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>
    </ScrollViewer>
</UserControl>
