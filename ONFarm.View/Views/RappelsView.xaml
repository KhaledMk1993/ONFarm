<UserControl
    x:Class="ONFarm.View.Views.RappelsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:ONFarm.ViewModel;assembly=ONFarm.ViewModel"
    d:DataContext="{d:DesignInstance Type=viewmodel:RappelsViewModel}"
    Background="{StaticResource LightGrayBrush}"
    mc:Ignorable="d">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Title  -->
        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,16"
            FontFamily="Segoe UI"
            FontSize="22"
            FontWeight="Bold"
            Foreground="{StaticResource TextDarkBrush}"
            Text="Rappels" />

        <!--  Content  -->
        <Border Grid.Row="1" Style="{StaticResource Card}">

            <ScrollViewer>

                <ItemsControl ItemsSource="{Binding Rappels}">

                    <ItemsControl.ItemTemplate>

                        <DataTemplate>

                            <Border
                                Margin="16,8"
                                Padding="16"
                                Background="{StaticResource LightGrayBrush}"
                                CornerRadius="10">

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Icon  -->
                                    <Border
                                        Grid.Column="0"
                                        Width="40"
                                        Height="40"
                                        Background="{StaticResource LightBlueBrush}"
                                        CornerRadius="20">

                                        <materialDesign:PackIcon
                                            Width="20"
                                            Height="20"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource BrandBlueBrush}"
                                            Kind="Bell" />

                                    </Border>

                                    <!--  Infos  -->
                                    <StackPanel
                                        Grid.Column="1"
                                        Margin="12,0"
                                        VerticalAlignment="Center">

                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextDarkBrush}"
                                            Text="{Binding Patient.NomComplet}" />

                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{StaticResource DarkGrayBrush}"
                                            Text="{Binding Patient.Telephone}" />

                                        <TextBlock
                                            Margin="0,2,0,0"
                                            FontSize="12"
                                            Foreground="{StaticResource DarkGrayBrush}"
                                            Text="{Binding Message}" />

                                        <StackPanel Margin="0,2,0,0" Orientation="Horizontal">

                                            <materialDesign:PackIcon
                                                Width="14"
                                                Height="14"
                                                Margin="0,0,4,0"
                                                Foreground="{StaticResource BrandOrangeBrush}"
                                                Kind="Calendar" />

                                            <TextBlock
                                                FontSize="11"
                                                Foreground="{StaticResource BrandOrangeBrush}"
                                                Text="{Binding DateRappel, StringFormat={}{0:dd/MM/yyyy}}" />

                                        </StackPanel>

                                    </StackPanel>

                                    <!--  Button Vu  -->
                                    <Button
                                        Grid.Column="2"
                                        Margin="0,0,8,0"
                                        Padding="12,6"
                                        Command="{Binding DataContext.MarquerVuCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding Id}"
                                        Style="{StaticResource PrimaryButton}">

                                        <StackPanel Orientation="Horizontal">

                                            <materialDesign:PackIcon
                                                Width="16"
                                                Height="16"
                                                Margin="0,0,6,0"
                                                Kind="Check" />

                                            <TextBlock Text="Vu" />

                                        </StackPanel>

                                    </Button>

                                </Grid>

                            </Border>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </ScrollViewer>

        </Border>

    </Grid>

</UserControl>