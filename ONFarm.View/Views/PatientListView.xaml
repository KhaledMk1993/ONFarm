<UserControl
    x:Class="ONFarm.View.Views.PatientListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:ONFarm.ViewModel;assembly=ONFarm.ViewModel"
    d:DataContext="{d:DesignInstance Type=viewmodel:PatientListViewModel,
                                     IsDesignTimeCreatable=True}"
    Background="#F0F2F5"
    mc:Ignorable="d">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="#0052CC" />
        <SolidColorBrush x:Key="PrimaryHover" Color="#0043A3" />
        <SolidColorBrush x:Key="PrimaryLight" Color="#E8F0FE" />
        <SolidColorBrush x:Key="SuccessColor" Color="#28A745" />
        <SolidColorBrush x:Key="DangerColor" Color="#DC3545" />
        <SolidColorBrush x:Key="BackgroundColor" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderColor" Color="#E0E0E0" />
        <SolidColorBrush x:Key="BorderFocus" Color="#0052CC" />
        <SolidColorBrush x:Key="TextPrimary" Color="#1A202C" />
        <SolidColorBrush x:Key="TextSecondary" Color="#718096" />
        <SolidColorBrush x:Key="SurfaceColor" Color="#F7FAFC" />

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="Height" Value="40" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="12"
                                    Opacity="0.25"
                                    ShadowDepth="3"
                                    Color="#0052CC" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="Height" Value="40" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="#F7FAFC" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryColor}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryLight}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ResetButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="#FEE2E2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Width" Value="185" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="IsTodayHighlighted" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border
                            x:Name="Root"
                            Background="White"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="8"
                                    Direction="270"
                                    Opacity="0.07"
                                    ShadowDepth="2" />
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!--  PART_Button = icône calendrier bleue, WPF l'utilise pour ouvrir le popup  -->
                                <Button
                                    x:Name="PART_Button"
                                    Grid.Column="0"
                                    Width="38"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Focusable="False">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border
                                                x:Name="BtnBd"
                                                Background="#F0F4FF"
                                                CornerRadius="9,0,0,9">
                                                <Path
                                                    Width="15"
                                                    Height="15"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Data="M19,3H18V1H16V3H8V1H6V3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M19,19H5V8H19V19M7,10H9V12H7V10M11,10H13V12H11V10M15,10H17V12H15V10M7,14H9V16H7V14M11,14H13V16H11V14M15,14H17V16H15V14Z"
                                                    Fill="#0052CC"
                                                    Stretch="Uniform" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="BtnBd" Property="Background" Value="#DBEAFE" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="BtnBd" Property="Background" Value="#BFDBFE" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!--  Séparateur  -->
                                <Rectangle
                                    Grid.Column="1"
                                    Width="1"
                                    Margin="0,8"
                                    Fill="#E2E8F0" />

                                <!--  Texte date sélectionnée  -->
                                <DatePickerTextBox
                                    x:Name="PART_TextBox"
                                    Grid.Column="2"
                                    Margin="10,0,6,0"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    CaretBrush="#0052CC"
                                    Cursor="Hand"
                                    FontFamily="Segoe UI"
                                    FontSize="13"
                                    Foreground="#1A202C"
                                    IsReadOnly="True" />

                                <!--  Popup géré par WPF via PART_Button  -->
                                <Popup
                                    x:Name="PART_Popup"
                                    Grid.Column="0"
                                    AllowsTransparency="True"
                                    Placement="Bottom"
                                    PlacementTarget="{Binding ElementName=Root}"
                                    StaysOpen="False"
                                    VerticalOffset="4">
                                    <Border
                                        Padding="4"
                                        Background="White"
                                        BorderBrush="#BFDBFE"
                                        BorderThickness="1.5"
                                        CornerRadius="12">
                                        <Border.Effect>
                                            <DropShadowEffect
                                                BlurRadius="20"
                                                Direction="270"
                                                Opacity="0.15"
                                                ShadowDepth="4" />
                                        </Border.Effect>
                                        <StackPanel>
                                            <Border
                                                Margin="-1,-1,-1,4"
                                                Padding="10,6"
                                                Background="{StaticResource PrimaryColor}"
                                                CornerRadius="9,9,0,0">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    FontFamily="Segoe UI"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Foreground="White"
                                                    Text="Choisir une date" />
                                            </Border>
                                            <Calendar
                                                x:Name="PART_Calendar"
                                                Background="White"
                                                BorderThickness="0"
                                                FontFamily="Segoe UI"
                                                FontSize="11"
                                                IsTodayHighlighted="True" />
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#0052CC" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#0052CC" />
                                <Setter TargetName="Root" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Padding="32,28,32,28" Background="#F0F2F5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  ══ Titre ══  -->
            <StackPanel
                Grid.Row="0"
                Margin="0,0,0,28"
                Orientation="Horizontal">
                <Border
                    Width="44"
                    Height="44"
                    Margin="0,0,14,0"
                    VerticalAlignment="Center"
                    Background="{StaticResource PrimaryColor}"
                    CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="10"
                            Opacity="0.3"
                            ShadowDepth="3"
                            Color="#0052CC" />
                    </Border.Effect>
                    <materialDesign:PackIcon
                        Width="22"
                        Height="22"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Kind="AccountGroup" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontFamily="Segoe UI"
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="{StaticResource TextPrimary}"
                        Text="Gestion des patients" />
                    <TextBlock
                        FontFamily="Segoe UI"
                        FontSize="12"
                        Foreground="{StaticResource TextSecondary}"
                        Text="Consultez, filtrez et gérez vos patients" />
                </StackPanel>
            </StackPanel>

            <!--  ══ Toolbar ══  -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Height="44"
                    Margin="0,0,12,0"
                    Background="White"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1.5"
                    CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Direction="270"
                            Opacity="0.06"
                            ShadowDepth="2" />
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Grid.Column="0"
                            Width="44"
                            Background="Transparent">
                            <Path
                                Width="16"
                                Height="16"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                                Fill="#A0AEC0"
                                Stretch="Uniform" />
                        </Border>
                        <TextBox
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            Foreground="{StaticResource TextPrimary}"
                            Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Resources>
                                        <VisualBrush
                                            x:Key="HintBrush"
                                            AlignmentX="Left"
                                            AlignmentY="Center"
                                            Stretch="None">
                                            <VisualBrush.Visual>
                                                <TextBlock
                                                    FontFamily="Segoe UI"
                                                    FontSize="13"
                                                    Foreground="#A0AEC0"
                                                    Text="Rechercher par nom, téléphone..." />
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Style.Resources>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{StaticResource HintBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <Border
                            Grid.Column="2"
                            Width="1"
                            Margin="0,8"
                            Background="{StaticResource BorderColor}" />
                        <Border
                            Grid.Column="2"
                            Width="44"
                            Margin="1,0,0,0"
                            Background="Transparent">
                            <Path
                                Width="14"
                                Height="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Data="M3,6H21V8H3V6M6,11H18V13H6V11M10,16H14V18H10V16Z"
                                Fill="#A0AEC0"
                                Stretch="Uniform" />
                        </Border>
                    </Grid>
                </Border>

                <Button
                    Grid.Column="1"
                    Margin="0,0,8,0"
                    Command="{Binding AddPatientCommand}"
                    Style="{StaticResource PrimaryButton}">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <Path
                            Width="14"
                            Height="14"
                            Margin="0,0,7,0"
                            VerticalAlignment="Center"
                            Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                            Fill="White"
                            Stretch="Uniform" />
                        <TextBlock VerticalAlignment="Center" Text="Nouveau patient" />
                    </StackPanel>
                </Button>

                <Button
                    Grid.Column="2"
                    Margin="0,0,8,0"
                    Command="{Binding ExportExcelCommand}"
                    Style="{StaticResource GhostButton}">
                    <StackPanel Orientation="Horizontal">
                        <Path
                            Width="14"
                            Height="14"
                            Margin="0,0,7,0"
                            VerticalAlignment="Center"
                            Data="M14,2L20,8V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V4A2,2 0 0,1 6,2H14M18,20V9H13V4H6V20H18M12,19L8,15H10.5V12H13.5V15H16L12,19Z"
                            Fill="{StaticResource TextSecondary}"
                            Stretch="Uniform" />
                        <TextBlock VerticalAlignment="Center" Text="Exporter" />
                    </StackPanel>
                </Button>

                <Button
                    Grid.Column="3"
                    Command="{Binding ImportExcelCommand}"
                    Style="{StaticResource GhostButton}">
                    <StackPanel Orientation="Horizontal">
                        <Path
                            Width="14"
                            Height="14"
                            Margin="0,0,7,0"
                            VerticalAlignment="Center"
                            Data="M14,2L20,8V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V4A2,2 0 0,1 6,2H14M18,20V9H13V4H6V20H18M12,11L16,15H13.5V18H10.5V15H8L12,11Z"
                            Fill="{StaticResource TextSecondary}"
                            Stretch="Uniform" />
                        <TextBlock VerticalAlignment="Center" Text="Importer" />
                    </StackPanel>
                </Button>
            </Grid>

            <!--  ══ Barre filtre date ══  -->
            <Border
                Grid.Row="2"
                Margin="0,0,0,16"
                Background="White"
                BorderThickness="1.5"
                CornerRadius="14">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Offset="0" Color="#E8F0FE" />
                        <GradientStop Offset="0.5" Color="#E0E0E0" />
                        <GradientStop Offset="1" Color="#E8F0FE" />
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="10"
                        Direction="270"
                        Opacity="0.07"
                        ShadowDepth="2" />
                </Border.Effect>

                <Grid Height="60">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  Icône calendrier  -->
                    <Border
                        Grid.Column="0"
                        Width="36"
                        Height="36"
                        Margin="16,0,12,0"
                        VerticalAlignment="Center"
                        Background="{StaticResource PrimaryLight}"
                        CornerRadius="8">
                        <Path
                            Width="16"
                            Height="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Data="M19,3H18V1H16V3H8V1H6V3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M19,19H5V8H19V19Z"
                            Fill="{StaticResource PrimaryColor}"
                            Stretch="Uniform" />
                    </Border>

                    <!--  Titre  -->
                    <TextBlock
                        Grid.Column="1"
                        Margin="0,0,16,0"
                        VerticalAlignment="Center"
                        FontFamily="Segoe UI"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimary}"
                        Text="Naissance entre" />

                    <!--  Séparateur  -->
                    <Rectangle
                        Grid.Column="2"
                        Width="1"
                        Height="28"
                        Margin="0,0,16,0"
                        VerticalAlignment="Center"
                        Fill="#E2E8F0" />

                    <!--  Badge DU  -->
                    <Border
                        Grid.Column="3"
                        Margin="0,0,8,0"
                        Padding="8,4"
                        VerticalAlignment="Center"
                        Background="{StaticResource PrimaryColor}"
                        CornerRadius="6">
                        <TextBlock
                            FontFamily="Segoe UI"
                            FontSize="10"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="DU" />
                    </Border>

                    <!--  DatePicker DU  -->
                    <DatePicker
                        Grid.Column="4"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        SelectedDate="{Binding FilterDateDebut, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource FilterDatePickerStyle}" />

                    <!--  Badge AU  -->
                    <Border
                        Grid.Column="5"
                        Margin="0,0,8,0"
                        Padding="8,4"
                        VerticalAlignment="Center"
                        Background="#0043A3"
                        CornerRadius="6">
                        <TextBlock
                            FontFamily="Segoe UI"
                            FontSize="10"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="AU" />
                    </Border>

                    <!--  DatePicker AU  -->
                    <DatePicker
                        Grid.Column="6"
                        VerticalAlignment="Center"
                        SelectedDate="{Binding FilterDateFin, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource FilterDatePickerStyle}" />

                    <!--  Badge filtre actif  -->
                    <Border
                        Grid.Column="7"
                        Margin="12,0,0,0"
                        Padding="10,5"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        CornerRadius="20">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDateFilterActive}" Value="True">
                                        <Setter Property="Background" Value="#EBF8FF" />
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse
                                Width="7"
                                Height="7"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Fill="#0052CC" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="Segoe UI"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource PrimaryColor}"
                                Text="Filtre actif" />
                        </StackPanel>
                    </Border>

                    <!--  Bouton Réinitialiser  -->
                    <Button
                        Grid.Column="8"
                        Margin="8,0,16,0"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding ResetDateFilterCommand}"
                        Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border
                                    x:Name="Bd"
                                    Padding="12,7"
                                    Background="Transparent"
                                    BorderBrush="#FCA5A5"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <StackPanel Orientation="Horizontal">
                                        <Path
                                            Width="12"
                                            Height="12"
                                            Margin="0,0,7,0"
                                            VerticalAlignment="Center"
                                            Data="M12,6V9L16,5L12,1V4A8,8 0 0,0 4,12C4,13.57 4.46,15.03 5.24,16.26L6.7,14.8C6.25,13.97 6,13 6,12A6,6 0 0,1 12,6M18.76,7.74L17.3,9.2C17.74,10.04 18,11 18,12A6,6 0 0,1 12,18V15L8,19L12,23V20A8,8 0 0,0 20,12C20,10.43 19.54,8.97 18.76,7.74Z"
                                            Fill="#DC3545"
                                            Stretch="Uniform" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontFamily="Segoe UI"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="#DC3545"
                                            Text="Réinitialiser" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#FFF5F5" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#FEE2E2" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
            <!--  ══ DataGrid ══  -->
            <Border
                Grid.Row="3"
                Background="White"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1.5"
                CornerRadius="14">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="16"
                        Direction="270"
                        Opacity="0.08"
                        ShadowDepth="4" />
                </Border.Effect>
                <DataGrid
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    BorderThickness="0"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserResizeRows="False"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    HorizontalGridLinesBrush="#F0F4F8"
                    IsReadOnly="True"
                    ItemsSource="{Binding Patients}"
                    RowHeight="52"
                    SelectionMode="Single"
                    SelectionUnit="FullRow">

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="BorderBrush" Value="#F0F4F8" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F7FAFF" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EBF3FF" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{StaticResource SurfaceColor}" />
                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                            <Setter Property="FontFamily" Value="Segoe UI" />
                            <Setter Property="FontSize" Value="11" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="Padding" Value="16,12" />
                            <Setter Property="BorderBrush" Value="#EDF2F7" />
                            <Setter Property="BorderThickness" Value="0,0,0,2" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="16,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border
                                            Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>

                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding NomComplet}"
                            Header="PATIENT">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontFamily" Value="Segoe UI" />
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn
                            Width="140"
                            Binding="{Binding Telephone}"
                            Header="TÉLÉPHONE">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontFamily" Value="Segoe UI" />
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn
                            Width="150"
                            Binding="{Binding DateNaissanceAffichage}"
                            Header="DATE NAISSANCE"
                            SortMemberPath="DateNaissance">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontFamily" Value="Segoe UI" />
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Width="160" Header="DERNIÈRE FACTURE">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="Segoe UI"
                                        FontSize="13">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding DerniereFacture, StringFormat=dd/MM/yyyy}" />
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DerniereFacture}" Value="{x:Null}">
                                                        <Setter Property="Text" Value="—" />
                                                        <Setter Property="Foreground" Value="#CBD5E0" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="160" Header="PROCHAINE FACTURE">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border
                                        Padding="10,4"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        CornerRadius="20">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F0FFF4" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ProchaineFacture}" Value="{x:Null}">
                                                        <Setter Property="Background" Value="Transparent" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock
                                            FontFamily="Segoe UI"
                                            FontSize="12"
                                            FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding ProchaineFacture, StringFormat=dd/MM/yyyy}" />
                                                    <Setter Property="Foreground" Value="#22863A" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ProchaineFacture}" Value="{x:Null}">
                                                            <Setter Property="Text" Value="—" />
                                                            <Setter Property="Foreground" Value="#CBD5E0" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="110" Header="ACTIONS">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Button
                                            Width="34"
                                            Height="34"
                                            Margin="0,0,6,0"
                                            Background="#EBF5FB"
                                            Command="{Binding DataContext.EditPatientCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource IconButton}"
                                            ToolTip="Modifier">
                                            <Path
                                                Width="14"
                                                Height="14"
                                                Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z"
                                                Fill="{StaticResource PrimaryColor}"
                                                Stretch="Uniform" />
                                        </Button>
                                        <Button
                                            Width="34"
                                            Height="34"
                                            Background="#FFF0F0"
                                            Command="{Binding DataContext.DeletePatientCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource IconButton}"
                                            ToolTip="Supprimer">
                                            <Path
                                                Width="14"
                                                Height="14"
                                                Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                                Fill="#E74C3C"
                                                Stretch="Uniform" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Border>
</UserControl>
