<Window
    x:Class="ONFarm.View.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:views="clr-namespace:ONFarm.View.Views"
    xmlns:vm="clr-namespace:ONFarm.ViewModel;assembly=ONFarm.ViewModel"
    Title="ON Farm"
    Width="1100"
    Height="700"
    MinWidth="900"
    MinHeight="600"
    Background="{StaticResource LightGrayBrush}"
    WindowStartupLocation="CenterScreen">


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  SIDEBAR  -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="10"
                    Direction="0"
                    ShadowDepth="2"
                    Color="#22000000" />
            </Border.Effect>

            <DockPanel>
                <!--  Logo  -->
                <Border Padding="0,24,0,16" DockPanel.Dock="Top">
                    <StackPanel HorizontalAlignment="Center">
                        <Border
                            Width="44"
                            Height="44"
                            Background="#22FFFFFF"
                            CornerRadius="12">
                            <materialDesign:PackIcon
                                Width="26"
                                Height="26"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="White"
                                Kind="LocalHospital" />
                        </Border>
                    </StackPanel>
                </Border>

                <!--  Séparateur  -->
                <Separator
                    Margin="12,0,12,8"
                    Background="#22FFFFFF"
                    DockPanel.Dock="Top" />

                <!--  Nav  -->
                <StackPanel Margin="0,4,0,0" DockPanel.Dock="Top">

                    <Button
                        Command="{Binding NavigateToDashboardCommand}"
                        Style="{StaticResource SidebarNavButton}"
                        ToolTip="Accueil">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                HorizontalAlignment="Center"
                                Foreground="#AEB6BF"
                                Kind="ViewDashboard" />
                            <TextBlock
                                Margin="0,3,0,0"
                                HorizontalAlignment="Center"
                                FontFamily="Segoe UI"
                                FontSize="10"
                                Foreground="#AEB6BF"
                                Text="Accueil" />
                        </StackPanel>
                    </Button>

                    <Button
                        Command="{Binding NavigateToAgendaCommand}"
                        Style="{StaticResource SidebarNavButton}"
                        ToolTip="Agenda">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                HorizontalAlignment="Center"
                                Foreground="#AEB6BF"
                                Kind="CalendarMonth" />
                            <TextBlock
                                Margin="0,3,0,0"
                                HorizontalAlignment="Center"
                                FontFamily="Segoe UI"
                                FontSize="10"
                                Foreground="#AEB6BF"
                                Text="Agenda" />
                        </StackPanel>
                    </Button>

                    <Button
                        Command="{Binding NavigateToPatientsCommand}"
                        Style="{StaticResource SidebarNavButton}"
                        ToolTip="Patients">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                HorizontalAlignment="Center"
                                Foreground="#AEB6BF"
                                Kind="AccountGroup" />
                            <TextBlock
                                Margin="0,3,0,0"
                                HorizontalAlignment="Center"
                                FontFamily="Segoe UI"
                                FontSize="10"
                                Foreground="#AEB6BF"
                                Text="Patients" />
                        </StackPanel>
                    </Button>

                    <Button
                        Command="{Binding NavigateToRappelsCommand}"
                        Style="{StaticResource SidebarNavButton}"
                        ToolTip="Rappels">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                HorizontalAlignment="Center"
                                Foreground="#AEB6BF"
                                Kind="Bell" />
                            <TextBlock
                                Margin="0,3,0,0"
                                HorizontalAlignment="Center"
                                FontFamily="Segoe UI"
                                FontSize="10"
                                Foreground="#AEB6BF"
                                Text="Rappels" />
                        </StackPanel>
                    </Button>

                </StackPanel>
            </DockPanel>
        </Border>

        <!--  CONTENU PRINCIPAL  -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Top Bar  -->
            <Border
                Grid.Row="0"
                Padding="24,0"
                Background="White">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="8"
                        Direction="270"
                        ShadowDepth="1"
                        Color="#15000000" />
                </Border.Effect>
                <DockPanel>
                    <StackPanel
                        VerticalAlignment="Center"
                        DockPanel.Dock="Left"
                        Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="Segoe UI"
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="{StaticResource BrandBlueBrush}"
                            Text="ON" />
                        <TextBlock
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            FontFamily="Segoe UI"
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="{StaticResource BrandGreenBrush}"
                            Text="Farm" />
                    </StackPanel>

                    <TextBlock
                        VerticalAlignment="Center"
                        DockPanel.Dock="Right"
                        FontFamily="Segoe UI"
                        FontSize="13"
                        Foreground="{StaticResource DarkGrayBrush}"
                        Text="{Binding DashboardVM.DateAujourdhui}" />

                    <TextBlock
                        Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Left"
                        FontFamily="Segoe UI"
                        FontSize="12"
                        Foreground="{StaticResource DarkGrayBrush}"
                        Text="Le pilotage intelligent des patients en pharmacie." />
                </DockPanel>
            </Border>

            <!--  Zone de contenu  -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}" />
        </Grid>
    </Grid>
</Window>