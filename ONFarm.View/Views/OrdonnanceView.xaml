<UserControl
    x:Class="ONFarm.View.Views.OrdonnanceView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:ONFarm.ViewModel;assembly=ONFarm.ViewModel"
    d:DataContext="{d:DesignInstance Type=viewmodel:OrdonnanceViewModel, IsDesignTimeCreatable=True}"
    Background="#F0F2F5"
    mc:Ignorable="d">

    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <SolidColorBrush x:Key="PrimaryColor"   Color="#0052CC" />
        <SolidColorBrush x:Key="PrimaryHover"   Color="#0043A3" />
        <SolidColorBrush x:Key="PrimaryLight"   Color="#E8F0FE" />
        <SolidColorBrush x:Key="PrimaryXLight"  Color="#EBF5FF" />
        <SolidColorBrush x:Key="BorderColor"    Color="#E2E8F0" />
        <SolidColorBrush x:Key="TextPrimary"    Color="#1A202C" />
        <SolidColorBrush x:Key="TextSecondary"  Color="#718096" />

        <!-- PrimaryButton -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource PrimaryColor}" />
            <Setter Property="Foreground"      Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="22,0" />
            <Setter Property="Height"          Value="42" />
            <Setter Property="FontFamily"      Value="Segoe UI" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}" CornerRadius="11">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" Opacity="0.28" ShadowDepth="4" Color="#0052CC" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GhostButton -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background"      Value="White" />
            <Setter Property="Foreground"      Value="{StaticResource TextSecondary}" />
            <Setter Property="BorderBrush"     Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Padding"         Value="20,0" />
            <Setter Property="Height"          Value="42" />
            <Setter Property="FontFamily"      Value="Segoe UI" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Bd" Property="Background"  Value="#F7FAFC" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryColor}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryLight}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SuccessButton -->
        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background"      Value="#22A245" />
            <Setter Property="Foreground"      Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="20,0" />
            <Setter Property="Height"          Value="42" />
            <Setter Property="FontFamily"      Value="Segoe UI" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}" CornerRadius="11">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" Opacity="0.22" ShadowDepth="3" Color="#22A245" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="#1A9138" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- IconButton -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}"
                                Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ModernTextBox -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background"               Value="White" />
            <Setter Property="BorderBrush"              Value="#E2E8F0" />
            <Setter Property="BorderThickness"          Value="1.5" />
            <Setter Property="Height"                   Value="42" />
            <Setter Property="Padding"                  Value="14,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontFamily"               Value="Segoe UI" />
            <Setter Property="FontSize"                 Value="13" />
            <Setter Property="Foreground"               Value="#1A202C" />
            <Setter Property="CaretBrush"               Value="#0052CC" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" Direction="270" Opacity="0.04" ShadowDepth="2" />
                            </Border.Effect>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="Bd" Property="BorderBrush"     Value="#0052CC" />
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- NotesTextBox -->
        <Style x:Key="NotesTextBox" BasedOn="{StaticResource ModernTextBox}" TargetType="TextBox">
            <Setter Property="Height"                      Value="84" />
            <Setter Property="TextWrapping"                Value="Wrap" />
            <Setter Property="AcceptsReturn"               Value="True" />
            <Setter Property="VerticalContentAlignment"    Value="Top" />
            <Setter Property="Padding"                     Value="14,10" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        </Style>

        <!-- ModernComboBox -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height"                   Value="42" />
            <Setter Property="FontFamily"               Value="Segoe UI" />
            <Setter Property="FontSize"                 Value="13" />
            <Setter Property="Foreground"               Value="#1A202C" />
            <Setter Property="Background"               Value="White" />
            <Setter Property="BorderBrush"              Value="#BFDBFE" />
            <Setter Property="BorderThickness"          Value="1.5" />
            <Setter Property="Cursor"                   Value="Hand" />
            <Setter Property="IsEditable"               Value="False" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd" Background="White"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" Direction="270" Opacity="0.06" ShadowDepth="2" />
                                </Border.Effect>
                            </Border>

                            <ToggleButton x:Name="PART_ToggleButton"
                                          Background="Transparent" BorderThickness="0"
                                          ClickMode="Press" Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" CornerRadius="10">
                                            <Path x:Name="Chevron"
                                                  Width="10" Height="6"
                                                  Margin="0,0,12,0"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Data="M0,0 L5,5 L10,0"
                                                  Stretch="Uniform" Stroke="#0052CC" StrokeThickness="1.8" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Chevron" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="180" CenterX="5" CenterY="3" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter x:Name="ContentSite"
                                              Margin="14,0,34,0" VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False" />

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True" Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" StaysOpen="False" VerticalOffset="4">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Padding="0" Background="White"
                                        BorderBrush="#BFDBFE" BorderThickness="1.5" CornerRadius="10">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="20" Direction="270" Opacity="0.12" ShadowDepth="4" />
                                    </Border.Effect>
                                    <StackPanel>
                                        <Border Padding="10,8" Background="#0052CC" CornerRadius="9,9,0,0">
                                            <TextBlock HorizontalAlignment="Center"
                                                       FontFamily="Segoe UI" FontSize="11"
                                                       FontWeight="SemiBold" Foreground="White"
                                                       Text="Sélectionner" />
                                        </Border>
                                        <ScrollViewer Margin="4,4,4,4"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#93C5FD" />
                                <Setter TargetName="Bd" Property="Background"  Value="#FAFCFF" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"     Value="#0052CC" />
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="FontFamily" Value="Segoe UI" />
                    <Setter Property="FontSize"   Value="13" />
                    <Setter Property="Foreground" Value="#1A202C" />
                    <Setter Property="Padding"    Value="14,10" />
                    <Setter Property="Cursor"     Value="Hand" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="ItemBd"
                                        Padding="{TemplateBinding Padding}"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="7">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="ItemBd" Property="Background" Value="#EBF5FF" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ItemBd" Property="Background" Value="#DBEAFE" />
                                        <Setter Property="Foreground" Value="#0052CC" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>

        <!-- ModernDatePicker -->
        <Style x:Key="ModernDatePicker" TargetType="DatePicker">
            <Setter Property="Background"         Value="White" />
            <Setter Property="BorderBrush"        Value="#E2E8F0" />
            <Setter Property="BorderThickness"    Value="1.5" />
            <Setter Property="Height"             Value="42" />
            <Setter Property="FontFamily"         Value="Segoe UI" />
            <Setter Property="FontSize"           Value="13" />
            <Setter Property="IsTodayHighlighted" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border x:Name="Root" Background="White"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" Direction="270" Opacity="0.04" ShadowDepth="2" />
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="PART_Button" Grid.Column="0" Width="40"
                                        BorderThickness="0" Cursor="Hand" Focusable="False">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="BtnBd" Background="#EBF5FF" CornerRadius="9,0,0,9">
                                                <Path Width="15" Height="15"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Data="M19,3H18V1H16V3H8V1H6V3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M19,19H5V8H19V19M7,10H9V12H7V10M11,10H13V12H11V10M15,10H17V12H15V10M7,14H9V16H7V14M11,14H13V16H11V14M15,14H17V16H15V14Z"
                                                      Fill="#0052CC" Stretch="Uniform" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="BtnBd" Property="Background" Value="#DBEAFE" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="BtnBd" Property="Background" Value="#BFDBFE" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Rectangle Grid.Column="1" Width="1" Margin="0,9" Fill="#BFDBFE" />
                                <DatePickerTextBox x:Name="PART_TextBox" Grid.Column="2"
                                                   Margin="12,0,8,0" VerticalAlignment="Center"
                                                   Background="Transparent" BorderThickness="0"
                                                   CaretBrush="#0052CC" Cursor="Hand"
                                                   FontFamily="Segoe UI" FontSize="13"
                                                   Foreground="#1A202C" IsReadOnly="True" />
                                <Popup x:Name="PART_Popup" Grid.Column="0"
                                       AllowsTransparency="True" Placement="Bottom"
                                       PlacementTarget="{Binding ElementName=Root}"
                                       StaysOpen="False" VerticalOffset="4">
                                    <Border Padding="4" Background="White"
                                            BorderBrush="#BFDBFE" BorderThickness="1.5" CornerRadius="12">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="20" Direction="270" Opacity="0.14" ShadowDepth="4" />
                                        </Border.Effect>
                                        <StackPanel>
                                            <Border Margin="-1,-1,-1,4" Padding="10,7"
                                                    Background="{StaticResource PrimaryColor}" CornerRadius="9,9,0,0">
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontFamily="Segoe UI" FontSize="11"
                                                           FontWeight="SemiBold" Foreground="White"
                                                           Text="Choisir une date" />
                                            </Border>
                                            <Calendar x:Name="PART_Calendar"
                                                      Background="White" BorderThickness="0"
                                                      FontFamily="Segoe UI" FontSize="11"
                                                      IsTodayHighlighted="True" />
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ModernDataGrid -->
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background"               Value="White" />
            <Setter Property="BorderThickness"          Value="0" />
            <Setter Property="GridLinesVisibility"      Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#F1F5F9" />
            <Setter Property="RowBackground"            Value="White" />
            <Setter Property="AlternatingRowBackground" Value="#FAFBFD" />
            <Setter Property="CanUserResizeRows"        Value="False" />
            <Setter Property="CanUserReorderColumns"    Value="False" />
            <Setter Property="SelectionMode"            Value="Single" />
            <Setter Property="FontFamily"               Value="Segoe UI" />
            <Setter Property="FontSize"                 Value="13" />
            <Setter Property="Foreground"               Value="#1A202C" />
            <Setter Property="RowHeight"                Value="56" />
            <Setter Property="ColumnHeaderHeight"       Value="44" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#F8FAFC" />
            <Setter Property="Foreground"      Value="#94A3B8" />
            <Setter Property="FontFamily"      Value="Segoe UI" />
            <Setter Property="FontSize"        Value="11" />
            <Setter Property="FontWeight"      Value="Bold" />
            <Setter Property="Padding"         Value="16,0" />
            <Setter Property="BorderBrush"     Value="#EEF2F7" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F7FF" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8F0FE" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="16,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="#1A202C" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#94A3B8" />
            <Setter Property="Margin"     Value="0,0,0,7" />
        </Style>

        <Style x:Key="SectionDivider" TargetType="Rectangle">
            <Setter Property="Height" Value="1" />
            <Setter Property="Fill"   Value="#EEF2F7" />
            <Setter Property="Margin" Value="0,4,0,16" />
        </Style>

    </UserControl.Resources>

    <Border Margin="24" Background="Transparent">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ══ LIGNE 0 : En-tête ══ -->
            <Grid Grid.Row="0" Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe UI" FontSize="24" FontWeight="Bold"
                               Foreground="#1A202C" Text="Gestion des Ordonnances" />
                    <TextBlock Margin="0,5,0,0" FontFamily="Segoe UI" FontSize="13" Foreground="#94A3B8"
                               Text="{Binding TotalCount, StringFormat='Total : {0} ordonnance(s)'}" />
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding OpenNewPanelCommand}" Style="{StaticResource PrimaryButton}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Width="14" Height="14" Margin="0,0,7,0" VerticalAlignment="Center"
                              Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                              Fill="White" Stretch="Uniform" />
                        <TextBlock VerticalAlignment="Center" Text="Nouvelle ordonnance" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ══ LIGNE 1 : Filtre GAUCHE — KPI DROITE ══ -->
            <Grid Grid.Row="1" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <!-- Filtre statut -->
                    <ColumnDefinition Width="210" />
                    <ColumnDefinition Width="12" />
                    <!-- Recherche -->
                    <ColumnDefinition Width="250" />
                    <!-- Spacer -->
                    <ColumnDefinition Width="*" />
                    <!-- Card Bientôt -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Card En Retard -->
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- ComboBox filtre — GAUCHE -->
                <ComboBox Grid.Column="0"
                          VerticalAlignment="Center"
                          ItemsSource="{Binding FilterOptions}"
                          SelectedItem="{Binding FilterType}"
                          Style="{StaticResource ModernComboBox}"
                          Validation.ErrorTemplate="{x:Null}" />

                <!-- Barre de recherche — GAUCHE -->
                <Border Grid.Column="2" Height="42"
                        Background="White" BorderBrush="#E2E8F0"
                        BorderThickness="1.5" CornerRadius="11">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" Direction="270" Opacity="0.05" ShadowDepth="2" />
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Width="16" Height="16"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                              Fill="#94A3B8" Stretch="Uniform" />
                        <TextBox Grid.Column="1" VerticalAlignment="Center"
                                 Background="Transparent" BorderThickness="0"
                                 FontFamily="Segoe UI" FontSize="13" Foreground="#1A202C"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Resources>
                                        <VisualBrush x:Key="HintBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                            <VisualBrush.Visual>
                                                <TextBlock FontFamily="Segoe UI" FontSize="13"
                                                           Foreground="#94A3B8" Text="Rechercher un patient…" />
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Style.Resources>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{StaticResource HintBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </Border>

                <!-- Card Bientôt — DROITE -->
                <Border Grid.Column="4" Margin="0,0,12,0" Padding="18,14"
                        Background="White" BorderBrush="#FED7AA"
                        BorderThickness="1.5" CornerRadius="14">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" Direction="270" Opacity="0.07" ShadowDepth="3" />
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" Margin="0,0,14,0" Background="#FEF3C7" CornerRadius="10">
                            <Path Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M11,7V13L15.25,15.58L16,14.33L12.5,12.25V7H11Z"
                                  Fill="#D97706" Stretch="Uniform" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontFamily="Segoe UI" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Text="BIENTÔT" />
                            <TextBlock FontFamily="Segoe UI" FontSize="26" FontWeight="Bold" Foreground="#92400E"
                                       Text="{Binding OrdonnancesImminentes}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Card En Retard — DROITE -->
                <Border Grid.Column="5" Padding="18,14"
                        Background="White" BorderBrush="#FECACA"
                        BorderThickness="1.5" CornerRadius="14">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" Direction="270" Opacity="0.07" ShadowDepth="3" />
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" Margin="0,0,14,0" Background="#FEE2E2" CornerRadius="10">
                            <Path Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M12,2L1,21H23M12,6L19.53,19H4.47M11,10V14H13V10M11,16V18H13V16"
                                  Fill="#DC2626" Stretch="Uniform" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontFamily="Segoe UI" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Text="EN RETARD" />
                            <TextBlock FontFamily="Segoe UI" FontSize="26" FontWeight="Bold" Foreground="#991B1B"
                                       Text="{Binding OrdonnancesEnRetard}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

            </Grid>

            <!-- ══ LIGNE 2 : Tableau + Panneau ══ -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Tableau -->
                <Border Grid.Column="0" Background="White" BorderThickness="0" CornerRadius="18">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Margin" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPanelVisible}" Value="True">
                                    <Setter Property="Margin" Value="0,0,18,0" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="22" Direction="270" Opacity="0.07" ShadowDepth="5" />
                    </Border.Effect>
                    <DataGrid AutoGenerateColumns="False" CanUserAddRows="False"
                              HorizontalScrollBarVisibility="Auto"
                              ItemsSource="{Binding FilteredOrdonnances}"
                              SelectedItem="{Binding SelectedOrdonnance}"
                              Style="{StaticResource ModernDataGrid}">
                        <DataGrid.Columns>

                            <DataGridTemplateColumn Width="*" MinWidth="180" Header="PATIENT">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="36" Height="36" Margin="0,0,12,0" CornerRadius="18">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E8F0FE" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Statut}" Value="Bientôt">
                                                                <Setter Property="Background" Value="#FEF3C7" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Statut}" Value="EnAttente">
                                                                <Setter Property="Background" Value="#EBF5FF" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"
                                                           Text="{Binding Patient.Initials}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#0052CC" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Statut}" Value="Bientôt">
                                                                    <Setter Property="Foreground" Value="#D97706" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Statut}" Value="EnAttente">
                                                                    <Setter Property="Foreground" Value="#1E40AF" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#1A202C" Text="{Binding Patient.FullName}" />
                                                <TextBlock FontFamily="Segoe UI" FontSize="11" Foreground="#94A3B8"
                                                           Text="{Binding Patient.Telephone}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="130" Header="DATE FACTURE">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="13" Height="13" Margin="0,0,7,0" VerticalAlignment="Center"
                                                  Data="M19,3H18V1H16V3H8V1H6V3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M19,19H5V8H19V19Z"
                                                  Fill="#94A3B8" Stretch="Uniform" />
                                            <TextBlock FontFamily="Segoe UI" FontSize="13" Foreground="#475569"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding DateFacture, StringFormat=dd/MM/yyyy}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="148" Header="RENOUVELLEMENT">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="13" Height="13" Margin="0,0,7,0" VerticalAlignment="Center"
                                                  Data="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z"
                                                  Fill="#0052CC" Stretch="Uniform" />
                                            <TextBlock FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#0052CC" VerticalAlignment="Center"
                                                       Text="{Binding ProchainRenouvellement, StringFormat=dd/MM/yyyy}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="125" Header="STATUT">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="11,5" HorizontalAlignment="Left"
                                                VerticalAlignment="Center" CornerRadius="20">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <!-- Défaut : Prepare → bleu -->
                                                    <Setter Property="Background" Value="#EBF5FF" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Statut}" Value="EnAttente">
                                                            <Setter Property="Background" Value="#FEF9C3" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Statut}" Value="Bientôt">
                                                            <Setter Property="Background" Value="#FFEDD5" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Statut}" Value="Livre">
                                                            <Setter Property="Background" Value="#DCFCE7" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="7" Height="7" Margin="0,0,7,0" VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <!-- Défaut : Prepare → bleu -->
                                                            <Setter Property="Fill" Value="#0052CC" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Statut}" Value="EnAttente">
                                                                    <Setter Property="Fill" Value="#EAB308" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Statut}" Value="Bientôt">
                                                                    <Setter Property="Fill" Value="#F97316" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Statut}" Value="Livre">
                                                                    <Setter Property="Fill" Value="#16A34A" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <!-- Défaut : Prepare → bleu -->
                                                            <Setter Property="Text"       Value="Préparé" />
                                                            <Setter Property="Foreground" Value="#1E40AF" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Statut}" Value="EnAttente">
                                                                    <Setter Property="Text"       Value="En attente" />
                                                                    <Setter Property="Foreground" Value="#854D0E" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Statut}" Value="Bientôt">
                                                                    <Setter Property="Text"       Value="Bientôt" />
                                                                    <Setter Property="Foreground" Value="#C2410C" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Statut}" Value="Livre">
                                                                    <Setter Property="Text"       Value="Livré" />
                                                                    <Setter Property="Foreground" Value="#166534" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="*" MinWidth="100" Header="NOTES">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#94A3B8"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                   Text="{Binding Notes}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="110" Header="ACTIONS">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                                            <Button Width="34" Height="34" Margin="0,0,6,0"
                                                    Background="#EBF5FB"
                                                    Command="{Binding DataContext.EditOrdonnanceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource IconButton}" ToolTip="Modifier">
                                                <Path Width="14" Height="14"
                                                      Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z"
                                                      Fill="#0052CC" Stretch="Uniform" />
                                            </Button>
                                            <Button Width="34" Height="34"
                                                    Background="#FFF0F0"
                                                    Command="{Binding DataContext.DeleteOrdonnanceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource IconButton}" ToolTip="Supprimer">
                                                <Path Width="14" Height="14"
                                                      Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                                      Fill="#E53E3E" Stretch="Uniform" />
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Panneau formulaire -->
                <Border Grid.Column="1" Width="370"
                        Background="White" BorderThickness="0" CornerRadius="18"
                        Validation.ErrorTemplate="{x:Null}"
                        Visibility="{Binding IsPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="22" Direction="270" Opacity="0.07" ShadowDepth="5" />
                    </Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="26">

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Width="4" Margin="0,0,12,0"
                                        Background="{StaticResource PrimaryColor}" CornerRadius="2" />
                                <TextBlock FontFamily="Segoe UI" FontSize="16" FontWeight="Bold"
                                           Foreground="#1A202C" VerticalAlignment="Center"
                                           Text="{Binding PanelTitle}" />
                            </StackPanel>

                            <Rectangle Style="{StaticResource SectionDivider}" />

                            <TextBlock Style="{StaticResource FormLabel}" Text="PATIENT" />

                            <Border Margin="0,0,0,8" Padding="12,8"
                                    Background="#EBF5FF" BorderBrush="#BFDBFE"
                                    BorderThickness="1.5" CornerRadius="10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedPatient}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="28" Height="28" CornerRadius="14"
                                            Background="{StaticResource PrimaryColor}" Margin="0,0,10,0">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontFamily="Segoe UI" FontSize="11" FontWeight="Bold"
                                                   Foreground="White" Text="{Binding SelectedPatient.Initials}" />
                                    </Border>
                                    <TextBlock VerticalAlignment="Center" FontFamily="Segoe UI"
                                               FontSize="13" FontWeight="SemiBold" Foreground="#1E40AF"
                                               Text="{Binding SelectedPatient.FullName}" />
                                </StackPanel>
                            </Border>

                            <Grid Margin="0,0,0,18">
                                <Border x:Name="SearchBorder" Height="42" Background="White"
                                        BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="10">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="6" Direction="270" Opacity="0.04" ShadowDepth="2" />
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Path Grid.Column="0" Width="15" Height="15"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                                              Fill="#94A3B8" IsHitTestVisible="False" Stretch="Uniform" />
                                        <TextBox Grid.Column="1" VerticalAlignment="Center"
                                                 Background="Transparent" BorderThickness="0"
                                                 FontFamily="Segoe UI" FontSize="13" Foreground="#1A202C"
                                                 Text="{Binding SearchPatient, UpdateSourceTrigger=PropertyChanged}">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Style.Resources>
                                                        <VisualBrush x:Key="PatientHint" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                            <VisualBrush.Visual>
                                                                <TextBlock FontFamily="Segoe UI" FontSize="13"
                                                                           Foreground="#94A3B8"
                                                                           Text="Tapez le nom du patient…" />
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Style.Resources>
                                                    <Style.Triggers>
                                                        <Trigger Property="Text" Value="">
                                                            <Setter Property="Background" Value="{StaticResource PatientHint}" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                        <Button Grid.Column="2" Width="24" Height="24" Margin="0,0,9,0"
                                                Background="Transparent" BorderThickness="0"
                                                Command="{Binding ClearPatientCommand}" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedPatient}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="ClearBd" Background="Transparent" CornerRadius="12">
                                                        <Path Width="10" Height="10"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                                                              Fill="#94A3B8" Stretch="Uniform" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ClearBd" Property="Background" Value="#FEE2E2" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>

                                <Popup x:Name="SuggestionsPopup"
                                       Width="{Binding ActualWidth, ElementName=SearchBorder}"
                                       AllowsTransparency="True"
                                       IsOpen="{Binding HasFilteredPatients, Mode=OneWay}"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding ElementName=SearchBorder}"
                                       StaysOpen="False" VerticalOffset="4">
                                    <Border MaxHeight="220" Padding="4" Background="White"
                                            BorderBrush="#BFDBFE" BorderThickness="1.5" CornerRadius="12">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="18" Direction="270" Opacity="0.12" ShadowDepth="4" />
                                        </Border.Effect>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding FilteredPatients}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border x:Name="SuggBd" Padding="12,10"
                                                                Background="Transparent" CornerRadius="8" Cursor="Hand">
                                                            <Border.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick"
                                                                              Command="{Binding DataContext.SelectPatientCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                              CommandParameter="{Binding}" />
                                                            </Border.InputBindings>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Width="32" Height="32" Margin="0,0,12,0"
                                                                        Background="#E8F0FE" CornerRadius="16">
                                                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                               FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"
                                                                               Foreground="#0052CC" Text="{Binding Initials}" />
                                                                </Border>
                                                                <StackPanel VerticalAlignment="Center">
                                                                    <TextBlock FontFamily="Segoe UI" FontSize="13"
                                                                               FontWeight="SemiBold" Foreground="#1A202C"
                                                                               Text="{Binding FullName}" />
                                                                    <TextBlock FontFamily="Segoe UI" FontSize="11"
                                                                               Foreground="#94A3B8" Text="{Binding Telephone}" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="#EBF5FB" />
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>

                            <TextBlock Style="{StaticResource FormLabel}" Text="DATE DE FACTURE" />
                            <DatePicker Margin="0,0,0,16"
                                        SelectedDate="{Binding DateFacture}"
                                        Style="{StaticResource ModernDatePicker}"
                                        Validation.ErrorTemplate="{x:Null}" />

                            <TextBlock Style="{StaticResource FormLabel}" Text="PROCHAIN RENOUVELLEMENT" />
                            <Grid Margin="0,0,0,16">
                                <DatePicker SelectedDate="{Binding ProchainRenouvellement}"
                                            Style="{StaticResource ModernDatePicker}"
                                            Validation.ErrorTemplate="{x:Null}" />
                                <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Margin="0,0,10,0" Padding="8,4"
                                        Background="#FEF3C7" CornerRadius="10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRenewalSoon}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontFamily="Segoe UI" FontSize="11" FontWeight="Bold"
                                               Foreground="#92400E"
                                               Text="{Binding DaysUntilRenewal, StringFormat='⚡ J-{0}'}" />
                                </Border>
                            </Grid>

                            <TextBlock Style="{StaticResource FormLabel}" Text="STATUT" />
                            <ComboBox Margin="0,0,0,16"
                                      ItemsSource="{Binding StatutOptions}"
                                      SelectedItem="{Binding SelectedStatut}"
                                      Style="{StaticResource ModernComboBox}"
                                      Validation.ErrorTemplate="{x:Null}" />

                            <TextBlock Style="{StaticResource FormLabel}" Text="NOTES" />
                            <TextBox Margin="0,0,0,20"
                                     Style="{StaticResource NotesTextBox}"
                                     Text="{Binding Notes, ValidatesOnDataErrors=False, ValidatesOnExceptions=False, UpdateSourceTrigger=PropertyChanged}"
                                     Validation.ErrorTemplate="{x:Null}" />

                            <Rectangle Margin="0,0,0,18" Style="{StaticResource SectionDivider}" />

                            <Grid>
                                <Grid.ColumnDefinitions>
