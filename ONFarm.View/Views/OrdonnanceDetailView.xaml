<UserControl
    x:Class="ONFarm.View.Views.OrdonnanceDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:ONFarm.View.Converters"
    xmlns:domain="clr-namespace:ONFarm.Domain.Entities;assembly=ONFarm.Domain"
    Background="#0F172A">

    <UserControl.Resources>

        <!--  Card style  -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <!--  Section header  -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <!--  Flat button base  -->
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="bd"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.65" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="BtnConfirm"
            BasedOn="{StaticResource FlatBtn}"
            TargetType="Button">
            <Setter Property="Background" Value="#166534" />
            <Setter Property="Foreground" Value="#4ADE80" />
        </Style>
        <Style
            x:Key="BtnNoAns"
            BasedOn="{StaticResource FlatBtn}"
            TargetType="Button">
            <Setter Property="Background" Value="#7C2D12" />
            <Setter Property="Foreground" Value="#FCA5A5" />
        </Style>
        <Style
            x:Key="BtnClose"
            BasedOn="{StaticResource FlatBtn}"
            TargetType="Button">
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="Foreground" Value="#64748B" />
        </Style>
        <Style
            x:Key="BtnSecondary"
            BasedOn="{StaticResource FlatBtn}"
            TargetType="Button">
            <Setter Property="Background" Value="#334155" />
            <Setter Property="Foreground" Value="#F1F5F9" />
        </Style>
        <Style
            x:Key="BtnPrimary"
            BasedOn="{StaticResource FlatBtn}"
            TargetType="Button">
            <Setter Property="Background" Value="#38BDF8" />
            <Setter Property="Foreground" Value="#0F172A" />
        </Style>
        <Style
            x:Key="BtnDanger"
            BasedOn="{StaticResource FlatBtn}"
            TargetType="Button">
            <Setter Property="Background" Value="#7F1D1D" />
            <Setter Property="Foreground" Value="#FCA5A5" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  ══ HEADER : Patient + téléphone + statut ═════════════════════  -->
            <Border Grid.Row="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  Avatar  -->
                    <Border
                        Grid.Column="0"
                        Width="52"
                        Height="52"
                        Margin="0,0,16,0"
                        Background="#334155"
                        CornerRadius="26">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="#38BDF8"
                            Text="{Binding Patient.Initiales}" />
                    </Border>

                    <!--  Nom + téléphone  -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="#F1F5F9"
                            Text="{Binding Patient.NomComplet}" />
                        <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                            <TextBlock FontSize="13" Text="📞 " />
                            <TextBlock
                                FontSize="15"
                                FontWeight="SemiBold"
                                Foreground="#38BDF8"
                                Text="{Binding Patient.Telephone}" />
                        </StackPanel>
                    </StackPanel>

                    <!--  Statut badge  -->
                    <Border
                        Grid.Column="2"
                        Padding="14,8"
                        VerticalAlignment="Center"
                        Background="{Binding Statut, Converter={StaticResource StatutColor}}"
                        CornerRadius="8">
                        <TextBlock
                            FontSize="12"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding Statut, Converter={StaticResource StatutText}}" />
                    </Border>
                </Grid>
            </Border>

            <!--  ══ ALERTE CRITIQUE (visible seulement si Critique) ═══════════  -->
            <Border
                Grid.Row="1"
                Margin="0,0,0,12"
                Padding="18,14"
                Background="#7F1D1D"
                CornerRadius="14"
                Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        FontSize="20"
                        Foreground="#FCA5A5"
                        Text="⚠" />
                    <StackPanel>
                        <TextBlock
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="#FCA5A5"
                            Text="ALERTE CRITIQUE — Patient introuvable" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="12"
                            Foreground="#FECACA"
                            Text="{Binding MessageCritique}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  ══ ACTIONS D'APPEL ════════════════════════════════════════════  -->
            <Border Grid.Row="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="RÉSULTAT DE L'APPEL" />

                    <!--  Boutons  -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <Button
                            Grid.Column="0"
                            Command="{Binding ConfirmerCommand}"
                            IsEnabled="{Binding PeutAgir}"
                            Style="{StaticResource BtnConfirm}">
                            <StackPanel>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="13"
                                    Text="✓  Patient a répondu" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="10"
                                    FontWeight="Normal"
                                    Opacity="0.75"
                                    Text="Prochain rappel auto calculé" />
                            </StackPanel>
                        </Button>

                        <Button
                            Grid.Column="2"
                            Command="{Binding MarquerNonReponduCommand}"
                            IsEnabled="{Binding PeutAgir}"
                            Style="{StaticResource BtnNoAns}">
                            <StackPanel>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="13"
                                    Text="✗  Pas de réponse" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="10"
                                    FontWeight="Normal"
                                    Opacity="0.75"
                                    Text="Relance urgente dans 24h" />
                            </StackPanel>
                        </Button>

                        <Button
                            Grid.Column="4"
                            Command="{Binding CloturerCommand}"
                            IsEnabled="{Binding PeutCloturer}"
                            Style="{StaticResource BtnDanger}">
                            <StackPanel>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="13"
                                    Text="⊗  Clôturer le dossier" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="10"
                                    FontWeight="Normal"
                                    Opacity="0.75"
                                    Text="Patient non récupérable" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!--  Compteur tentatives  -->

                </StackPanel>
            </Border>

            <!--  ══ TIMELINE RAPPELS UNIQUEMENT ═══════════════════════════════  -->
            <Border Grid.Row="3" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="HISTORIQUE DES RAPPELS" />

                    <TextBlock
                        FontSize="13"
                        Foreground="#475569"
                        Text="Aucun rappel enregistré."
                        Visibility="Collapsed" />

                    <ItemsControl ItemsSource="{Binding Contacts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Ellipse
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Width="10"
                                        Height="10"
                                        Margin="0,4,0,0"
                                        VerticalAlignment="Top"
                                        Fill="{Binding Couleur}" />
                                    <Rectangle
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Width="1"
                                        MinHeight="8"
                                        HorizontalAlignment="Center"
                                        Fill="#334155" />

                                    <StackPanel
                                        Grid.Row="0"
                                        Grid.RowSpan="2"
                                        Grid.Column="2"
                                        Margin="12,0,0,0">
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="#475569"
                                            Text="{Binding DateLabel}" />
                                        <TextBlock
                                            Margin="0,2,0,0"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="#F1F5F9"
                                            Text="{Binding Titre}" />
                                        <TextBlock
                                            Margin="0,2,0,0"
                                            FontSize="12"
                                            Foreground="#64748B"
                                            Text="{Binding Sous}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!--  ══ DIALOG CLÔTURE (inline) ═══════════════════════════════════  -->
            <Border
                Grid.Row="3"
                Padding="20"
                Background="#1E2D3D"
                CornerRadius="14"
                Visibility="{Binding ShowCloturDialog, Converter={StaticResource BoolVis}}">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="15"
                        FontWeight="Bold"
                        Foreground="#FCA5A5"
                        Text="Confirmer la clôture du dossier" />
                    <TextBlock
                        Margin="0,0,0,16"
                        FontSize="13"
                        Foreground="#94A3B8"
                        TextWrapping="Wrap">
                        Le dossier sera archivé. Plus aucun rappel ne sera créé. Action définitive.
                    </TextBlock>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="RAISON" />
                    <Border
                        Margin="0,0,0,16"
                        Background="#0F172A"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        CornerRadius="8">
                        <TextBox
                            Height="80"
                            Padding="12,10"
                            AcceptsReturn="True"
                            Background="Transparent"
                            BorderThickness="0"
                            CaretBrush="#38BDF8"
                            FontSize="13"
                            Foreground="#F1F5F9"
                            Text="{Binding RaisonCloture, UpdateSourceTrigger=PropertyChanged}"
                            TextWrapping="Wrap" />
                    </Border>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            Margin="0,0,10,0"
                            Command="{Binding AnnulerCloturCommand}"
                            Content="Annuler"
                            Style="{StaticResource BtnSecondary}" />
                        <Button
                            Command="{Binding ValiderCloturCommand}"
                            Content="Confirmer la clôture"
                            Style="{StaticResource BtnDanger}" />
                    </StackPanel>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>
