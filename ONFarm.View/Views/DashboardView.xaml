<UserControl
    x:Class="ONFarm.View.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:ONFarm.ViewModel;assembly=ONFarm.ViewModel"
    d:DataContext="{d:DesignInstance Type=viewmodel:DashboardViewModel}"
    Background="{StaticResource LightGrayBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Tabs  -->
        <Border
            Grid.Row="0"
            Padding="24,0,24,0"
            Background="White"
            BorderBrush="{StaticResource MidGrayBrush}"
            BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button
                    Command="{Binding SwitchTabCommand}"
                    CommandParameter="Vue d'ensemble"
                    Content="Vue d'ensemble"
                    Style="{StaticResource TabButtonActive}" />
                <Button
                    Command="{Binding SwitchTabCommand}"
                    CommandParameter="Agenda"
                    Content="Agenda"
                    Style="{StaticResource TabButton}" />
                <Button
                    Command="{Binding SwitchTabCommand}"
                    CommandParameter="Rappels"
                    Content="Patients à rappeler"
                    Style="{StaticResource TabButton}" />
            </StackPanel>
        </Border>

        <!--  Stats Cards  -->
        <Grid Grid.Row="1" Margin="24,16,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <!--  Card: Total patients  -->
            <Border
                Grid.Column="0"
                Margin="0,0,8,0"
                Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock
                        FontFamily="Segoe UI"
                        FontSize="12"
                        Foreground="{StaticResource DarkGrayBrush}"
                        Text="Total patients" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontFamily="Segoe UI"
                        FontSize="32"
                        FontWeight="Bold"
                        Foreground="{StaticResource BrandBlueBrush}"
                        Text="{Binding TotalPatients}" />
                    <TextBlock
                        FontFamily="Segoe UI"
                        FontSize="11"
                        Foreground="{StaticResource DarkGrayBrush}"
                        Text="patients actifs" />
                </StackPanel>
            </Border>

            <!--  Card: Rappels du jour  -->
            <Border
                Grid.Column="1"
                Margin="4,0,4,0"
                Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock
                        FontFamily="Segoe UI"
                        FontSize="12"
                        Foreground="{StaticResource DarkGrayBrush}"
                        Text="Rappels du jour" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontFamily="Segoe UI"
                        FontSize="32"
                        FontWeight="Bold"
                        Foreground="{StaticResource BrandOrangeBrush}"
                        Text="{Binding RappelsDuJour}" />
                    <TextBlock
                        FontFamily="Segoe UI"
                        FontSize="11"
                        Foreground="{StaticResource DarkGrayBrush}"
                        Text="à contacter aujourd'hui" />
                </StackPanel>
            </Border>

            <!--  Card: Ordonnances imminentes  -->
            <Border
                Grid.Column="2"
                Margin="8,0,0,0"
                Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock
                        FontFamily="Segoe UI"
                        FontSize="12"
                        Foreground="{StaticResource DarkGrayBrush}"
                        Text="Ordonnances à préparer" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontFamily="Segoe UI"
                        FontSize="32"
                        FontWeight="Bold"
                        Foreground="{StaticResource BrandGreenBrush}"
                        Text="{Binding OrdonnancesImminentes}" />
                    <TextBlock
                        FontFamily="Segoe UI"
                        FontSize="11"
                        Foreground="{StaticResource DarkGrayBrush}"
                        Text="dans les 48h" />
                </StackPanel>
            </Border>
        </Grid>

        <!--  Main Content: Patients table + Rappels panel  -->
        <Grid Grid.Row="2" Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!--  Patients table  -->
            <Border
                Grid.Column="0"
                Margin="0,0,12,0"
                Padding="0"
                Style="{StaticResource Card}">
                <DockPanel>
                    <!--  Header  -->
                    <Grid Margin="20,16,20,0" DockPanel.Dock="Top">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="Segoe UI"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextDarkBrush}"
                            Text="Patients" />
                    </Grid>

                    <!--  Add patient button  -->
                    <Button
                        Margin="20,12,20,8"
                        Command="{Binding AddPatientCommand}"
                        DockPanel.Dock="Top"
                        FontSize="14"
                        Style="{StaticResource PrimaryButton}">

                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                Margin="0,0,8,0"
                                Kind="Plus" />

                            <TextBlock Text="Ajouter un patient" />
                        </StackPanel>

                    </Button>

                    <!--  DataGrid  -->
                    <DataGrid
                        Margin="0,0,0,0"
                        ItemsSource="{Binding Patients}"
                        MouseDoubleClick="DataGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn
                                Width="*"
                                MinWidth="140"
                                Header="Patient(e)">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontFamily="Segoe UI"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource BrandBlueBrush}"
                                            Text="{Binding NomComplet}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn
                                Width="130"
                                Binding="{Binding DerniereFacture, StringFormat=dd MMM yyyy}"
                                ElementStyle="{StaticResource BaseTextStyle}"
                                Header="Dernière facture" />
                            <DataGridTemplateColumn Width="110" Header="Fact. manquées">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border
                                            HorizontalAlignment="Center"
                                            Style="{StaticResource Badge}"
                                            Visibility="{Binding NombreFacturesManquees, Converter={StaticResource IntToVisibilityConverter}}">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                FontWeight="Bold"
                                                Foreground="White"
                                                Text="{Binding NombreFacturesManquees}" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn
                                Width="130"
                                Binding="{Binding ProchaineFacture, StringFormat=dd MMM yyyy}"
                                ElementStyle="{StaticResource BaseTextStyle}"
                                Header="Prochaine facture" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!--  Rappels panel  -->
            <Border
                Grid.Column="1"
                Padding="0"
                Style="{StaticResource Card}">
                <DockPanel>
                    <!--  Header  -->
                    <Grid Margin="16,16,16,12" DockPanel.Dock="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="Segoe UI"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextDarkBrush}"
                            Text="Patients à rappeler" />
                        <Border Grid.Column="1" Style="{StaticResource Badge}">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="12"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="{Binding RappelsDuJour}" />
                        </Border>
                    </Grid>

                    <!--  Rappels list  -->
                    <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding RappelsUrgents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="12,4"
                                        Padding="12"
                                        Background="{StaticResource LightGrayBrush}"
                                        CornerRadius="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <!--  Avatar  -->
                                            <Border
                                                Grid.Column="0"
                                                Width="36"
                                                Height="36"
                                                Background="{StaticResource MidGrayBrush}"
                                                CornerRadius="18">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="18"
                                                    Text="👤" />
                                            </Border>
                                            <!--  Info  -->
                                            <StackPanel
                                                Grid.Column="1"
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center">
                                                <TextBlock
                                                    FontFamily="Segoe UI"
                                                    FontSize="13"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource TextDarkBrush}"
                                                    Text="{Binding Patient.NomComplet}" />
                                                <TextBlock
                                                    FontFamily="Segoe UI"
                                                    FontSize="11"
                                                    Foreground="{StaticResource DarkGrayBrush}"
                                                    Text="{Binding Patient.Telephone}" />
                                                <TextBlock
                                                    FontFamily="Segoe UI"
                                                    FontSize="11"
                                                    Foreground="{StaticResource DarkGrayBrush}"
                                                    Text="{Binding Message}"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                            <!--  Arrow  -->
                                            <TextBlock
                                                Grid.Column="2"
                                                VerticalAlignment="Center"
                                                FontSize="20"
                                                Foreground="{StaticResource DarkGrayBrush}"
                                                Text="›" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
